diff --git a/src/config/win-pre.in b/src/config/win-pre.in
index 0bcb280..c709e6f 100644
--- a/src/config/win-pre.in
+++ b/src/config/win-pre.in
@@ -126,6 +126,18 @@ CCOPTS=-nologo /EHsc /W3 /we4020 /we4024 /we4047 $(PDB_OPTS) $(DLL_FILE_DEF)
 LOPTS=-nologo -incremental:no -manifest
 
 CCLINKOPTION=
+# Some Windows helper executables are run during the build.  When
+# cross-compiling, build those helpers for the build machine rather
+# than the target machine.
+!ifndef CC_FOR_BUILD
+CC_FOR_BUILD=$(CC)
+!endif
+
+MIDL_TARGET=
+!if "$(CPU)" == "ARM64"
+MIDL_TARGET=/env arm64
+!endif
+
 DEBUGOPT=/guard:cf /Zi
 
 #if the compiler is vstudio 8, generate manifest
