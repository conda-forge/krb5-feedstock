@@ -126,6 +126,31 @@
 LOPTS=-nologo -incremental:no -manifest
 
 CCLINKOPTION=
+# Some Windows helper executables are run during the build.  When
+# cross-compiling, build those helpers for the build machine rather
+# than the target machine.
+!ifndef BUILD_CC
+BUILD_CC=$(CC)
+!endif
+!ifndef BUILD_CCLINKOPTION
+BUILD_CCLINKOPTION=$(CCLINKOPTION)
+!endif
+!if "$(CC_FOR_BUILD)" != ""
+BUILD_CC=$(CC_FOR_BUILD)
+!endif
+
+!ifndef WCONFIG_CC
+WCONFIG_CC=$(BUILD_CC)
+!endif
+!ifndef WCONFIG_CCLINKOPTION
+WCONFIG_CCLINKOPTION=$(BUILD_CCLINKOPTION)
+!endif
+
+MIDL_TARGET=
+!if "$(CPU)" == "ARM64"
+MIDL_TARGET=/env arm64
+!endif
+
 DEBUGOPT=/guard:cf /Zi
 
 #if the compiler is vstudio 8, generate manifest
